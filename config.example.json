{
  "seeds": [
    "https://docs.aws.amazon.com/",
    "https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/concepts.html",
    "https://docs.aws.amazon.com/AmazonS3/latest/userguide/Welcome.html",
    "https://docs.aws.amazon.com/IAM/latest/UserGuide/introduction.html"
  ],
  "allowed_hosts": [
    "docs.aws.amazon.com"
  ],
  "output_dir": "docs",
  "metadata_db": "metadata/crawl.db",
  "enable_robots_sitemaps": true,
  "max_sitemap_urls": 50000,
  "max_sitemap_files": 1000,
  "user_agent": "aws-docs-mirror/0.1 (+https://github.com/groovy-sky/aws-docs)",
  "concurrency": 2,
  "requests_per_second": 1,
  "burst": 1,
  "max_retries": 3,
  "request_timeout_seconds": 20,
  "max_pages": 25,
  "selectors": [
    "#main-content",
    "main",
    "article",
    ".awsdocs-content"
  ],
  "exclude_selectors": [
    "script",
    "style",
    "noscript",
    "iframe",
    "header",
    "footer",
    "nav",
    "aside",
    ".breadcrumbs",
    ".awsdocs-toc"
  ]
}
